# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (never commit secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# local databases
*.db
*.db-journal

# user uploads (keep .gitkeep)
/public/uploads/avatars/*
!/public/uploads/avatars/.gitkeep
/public/uploads/dorm-logos/*
!/public/uploads/dorm-logos/.gitkeep
/public/uploads/dorm-payment-proofs/*
!/public/uploads/dorm-payment-proofs/.gitkeep
/public/uploads/attendance-faces/*
!/public/uploads/attendance-faces/.gitkeep
/public/uploads/village-slips/*
!/public/uploads/village-slips/.gitkeep
/public/uploads/building-pos/*
!/public/uploads/building-pos/.gitkeep
/public/uploads/home-finance/*
!/public/uploads/home-finance/.gitkeep
/public/uploads/attendance-roster/*
!/public/uploads/attendance-roster/.gitkeep
/public/uploads/car-wash/*
!/public/uploads/car-wash/.gitkeep

# Legacy duplicate tree — แอปจริงอยู่ราก repo (มี node_modules/.next ของ copy เก่า)
/web/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
