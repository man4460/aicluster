# MySQL บนเครื่อง (แก้ user, password, พอร์ต ตามจริง)
# แอปรันบนเครื่องเดียวกับ DB → ใช้ localhost ได้ (อุปกรณ์อื่นใน WiFi เข้าแค่เว็บ ไม่ต่อ DB โดยตรง)
DATABASE_URL="mysql://root:YOUR_PASSWORD@localhost:3306/mawell_buffet"
AUTH_SECRET="replace-with-at-least-32-random-characters-here"
APP_URL="http://localhost:3000"
# --- แยก dev จากโปรดักชัน (แนะนำ) ---
# 1) สร้างฐานข้อมูล MySQL คนละชื่อ เช่น mawell_buffet_dev — ใส่ใน .env.local เมื่อรัน dev เท่านั้น
#    DATABASE_URL="mysql://...@localhost:3306/mawell_buffet_dev"
# 2) รัน dev ที่พอร์ต 3001: npm run dev:3001  (โปรดักชันคงใช้ next start / PM2 ที่ 3000)
#    ถ้า SSR/แคช .next ค้างไม่ตรงกับโค้ด (hydration warning): หยุด dev แล้วรัน npm run dev:3001:clean — ลบโฟลเดอร์ .next ในโปรเจกต์ (บน Windows ให้ cd เข้าโฟลเดอร์โปรเจกต์ก่อน ไม่ต้องลบ Z:\.next แยกถ้าโปรเจกต์อยู่ที่ Z:\...)
#    จากนั้น hard refresh ในเบราว์เซอร์ (Ctrl+Shift+R)
#    Next รีเฟรชหน้าเมื่อแก้โค้ดอยู่แล้ว — ถ้าต้องการให้ prisma generate อัตโนมัติเมื่อแก้ schema: npm run dev:3001:watch
# 3) Cloudflare Tunnel / DNS: ชี้โดเมนทดสอบ (เช่น dev.ma-well.com) ไป origin http://127.0.0.1:3001
# 4) ตั้ง APP_URL + NEXT_PUBLIC_APP_URL ให้ตรง URL ที่เปิดจริง (รวมพอร์ตถ้าไม่ผ่าน tunnel)
#    APP_URL="https://dev.ma-well.com"   NEXT_PUBLIC_APP_URL="https://dev.ma-well.com"
# 5) Google OAuth: เพิ่ม Authorized redirect URI สำหรับ dev เช่น https://dev.ma-well.com/api/auth/google/callback
#    (อย่าใช้ DATABASE_URL โปรดักชันกับเครื่องที่แก้โค้ด — migrate/seed จะไปกระทบข้อมูลจริง)

# Cloudflare Tunnel ตัวอย่าง — ใส่ path ท้ายได้ (เช่น /dashboard); ระบบใช้เฉพาะ origin สำหรับลิงก์สาธารณะ / OAuth
# APP_URL="https://demo.ma-well.com/dashboard"
# NEXT_PUBLIC_APP_URL="https://demo.ma-well.com/dashboard"
# next.config อนุญาต *.ma-well.com ใน allowedDevOrigins แล้ว — โดเมนอื่นเพิ่ม ALLOWED_DEV_ORIGINS=hostname
# APP_URL="https://demo.example.com"
# NEXT_PUBLIC_APP_URL="https://demo.example.com"

# --- เข้าสู่ระบบด้วย Google (OAuth 2.0) ---
# แบบ MelodyWebapp (แนะนำถ้า redirect + secret มีปัญหา): ตั้ง NEXT_PUBLIC_GOOGLE_CLIENT_ID เท่านั้น + Authorized JavaScript origins
#   แอปใช้ @react-oauth/google แล้ว POST /api/auth/google/token — ไม่ต้องใส่ GOOGLE_CLIENT_SECRET
# แบบ redirect (server): ต้องมี GOOGLE_CLIENT_ID + GOOGLE_CLIENT_SECRET + Authorized redirect URI ให้ตรงทุกตัวอักษร:
#   (เหมือน YOUR_REDIRECT_URL ใน googleapis — ต้องเป็นที่ Google redirect กลับมา ไม่ใช่หน้า /dashboard หลังล็อกอิน)
#   http://localhost:3000/api/auth/google/callback
#   https://demo.ma-well.com/api/auth/google/callback  (ถ้าใช้ Cloudflare Tunnel)
#   https://buffet.ma-well.com/api/auth/google/callback  (โปรดักชัน — ต้องตรงทุกตัวอักษรกับ Google Console)
#   และ URL โปรดักชันจริง เช่น https://your-domain.com/api/auth/google/callback
# Authorized JavaScript origins: http://localhost:3000 และ https://โดเมนที่ใช้จริง (ไม่มี path ต่อท้าย)
# OAuth consent screen → ถ้าสถานะ **Testing**: เพิ่มอีเมล Google ที่จะล็อกอินในรายการ Test users ไม่งั้นจะโดนบล็อก
# ถ้าใช้โดเมนสาธารณะ: เพิ่ม Authorized domains (เช่น ma-well.com) และยืนยันโดเมนตามที่ Google ขอ
# Error 400 invalid_request / นโยบายความปลอดภัย: เช็ก redirect URI + origins + test users ก่อน
# รัน migrate หลังเพิ่มฟิลด์ google_sub (ดู prisma/migrations/*user_google_oauth*)
# GOOGLE_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...
# หรือใส่ Client ID แบบสาธารณะ (ค่าเดียวกับบรรทัดบนได้) — ร่วมกับ GOOGLE_CLIENT_SECRET ด้านบน
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=....apps.googleusercontent.com

# --- หลายโดเมนย่อย (เช่น app.ma-well.com กับ buffet.ma-well.com) ---
# ค่าเริ่มต้น: คุกกี้ session ผูกกับ host ที่ล็อกอินเท่านั้น — ล็อกที่ buffet แล้วเปิด app จะไม่มี session
# ตั้งเป็น parent domain (มีจุดนำหน้า) ให้เบราว์เซอร์ส่งคุกกี้ทุกโดเมนย่อย:
# COOKIE_DOMAIN=.ma-well.com
# โปรดักชัน: ตั้งแล้วให้ผู้ใช้ล็อกอินใหม่ครั้งหนึ่ง (คุกกี้เก่าเป็น host-only จะไม่ถูกลบข้ามโดเมน)

# --- เข้าจาก WiFi / LAN เดียวกัน ---
# รัน production (next start / PM2) แต่เปิดด้วย http://192.168.x.x → ต้องปิด Secure cookie ไม่งั้นล็อกอินไม่ติด
# COOKIE_SECURE=false
# โหมด dev: ถ้า IP ไม่อยู่ในช่วง 192.168 / 10.x ให้ระบุ host เอง (คั่นด้วย comma)
# ALLOWED_DEV_ORIGINS=192.168.1.88
# ลิงก์/QR ให้ตรงกับ URL ที่เปิดจริง (ถ้าเข้าจากมือถือด้วย IP ของ PC)
# NEXT_PUBLIC_APP_URL="http://192.168.1.88:3000"
# ลิงก์สาธารณะ / QR (ถ้าไม่ตั้ง จะใช้ APP_URL หรือ Host จาก request; บน Vercel มี VERCEL_URL)
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# --- Chat AI แบบฟรี (Ollama บนเครื่อง — ไม่ใช้ API ค่าใช้จ่าย) ---
# คู่มือรวม (โมเดล, ส่งรูป, สลิป, บันทึกบัญชี): docs/README.md
# สูตร Ollama โลคัล 100% ฟรี (ไม่ OpenClaw / ไม่ Telegram / ไม่โมเดล :cloud): docs/README.md — ค้นหา "สูตรตั้งค่า"
# แดชบอร์ด: /dashboard/chat-ai (ลิงก์เก่า /dashboard/chatai redirect มาที่นี่)
# 1) แชทข้อความ: ตั้ง OLLAMA_API_URL (หรือ OLLAMA_URL) + OLLAMA_MODEL
#    ตัวอย่าง Kimi K2.5 ใน Ollama library:  ollama pull kimi-k2.5:cloud
#    OLLAMA_API_URL="http://127.0.0.1:11434/api/generate"
#    OLLAMA_MODEL="kimi-k2.5:cloud"
# 2) อ่านสลิป → ยืนยันบันทึก: GLM-OCR (ปุ่มในแชท)  ollama pull glm-ocr:latest
#    ดูบรรทัด OLLAMA_GLM_OCR_* ด้านล่าง
# 3) รูปในแชท (วิเคราะห์สลิปทั่วไป / ไม่ส่ง Telegram): ตั้ง OLLAMA_VISION_API_URL + OLLAMA_VISION_MODEL
# ถ้าไม่ตั้ง OpenClaw: แชทใช้ Ollama ตามนี้ได้ทันที (ข้อความ = OLLAMA_MODEL, รูป = ชุด VISION ถ้ามี)

# --- AI อ่านสลิป (รายรับ/รายจ่าย) + แชท AI ---
# แชท AI (น้องมาเวล): ลอง Ollama ก่อน (รูป แล้วข้อความ) → ถ้ายังไม่ได้ผลและตั้ง Telegram ไว้ อาจส่งรูปต่อในกลุ่ม → ถ้ายังไม่มีคำตอบค่อยเรียก OpenClaw Agent (WS + API key) — ไม่ใช่ OpenClaw ก่อน Ollama
# OpenClaw
# รวม endpoint เดียว (ข้อความ + รูป): POST JSON { "message" } หรือ { "message", "image" } — ตอบ { "content" } — โค้ดจะใช้ payload นี้เมื่อ URL มี /api/openclaw/ocr
# หรือกำหนดบังคับ: OPENCLAW_HTTP_MESSAGE_PAYLOAD=1
# OPENCLAW_HTTP_MESSAGE_PAYLOAD=1
# OPENCLAW_API_URL="http://192.168.1.191:3000/api/openclaw/ocr"
# OPENCLAW_API_KEY=""
# OpenClaw Agent API (แชท AI ส่วนตัว)
# OPENCLAW_AGENT_API_URL="http://127.0.0.1:8000/v1/agent/chat"
# OPENCLAW_AGENT_API_KEY=""
# OPENCLAW_AGENT_MODEL="openclaw-agent"
# Shared secret for inbound OpenClaw sync webhook:
# POST /api/sync/openclaw/events with header `x-openclaw-sync-secret` (or Bearer token)
# OPENCLAW_SYNC_SECRET="replace-with-long-random-secret"
# Pull mode (project -> OpenClaw): endpoint on OpenClaw machine that returns { events: [...] }
# OPENCLAW_SYNC_PULL_URL="http://192.168.1.194:3000/api/sync/export"
# optional, defaults to OPENCLAW_SYNC_SECRET
# OPENCLAW_REMOTE_SYNC_SECRET="replace-with-openclaw-secret"
# optional bearer auth for OpenClaw export endpoint
# OPENCLAW_SYNC_PULL_BEARER=""
# Ollama — แชทข้อความใช้ OLLAMA_MODEL; อ่านรูปสลิปใช้ OLLAMA_VISION_MODEL (ดีฟอลต์ qwen2.5vl:7b ในโค้ด)
# รูป: โค้ดจะเรียก /api/chat ก่อน แล้วค่อย /api/generate (รองรับ qwen2.5-vl) — ตั้ง URL เป็นชี้ host หรือ /api/generate ก็ได้
# OLLAMA_API_URL="http://127.0.0.1:11434/api/generate"
# OLLAMA_MODEL="llama3.2:3b"
# OLLAMA_VISION_MODEL="qwen2.5vl:7b"
# ถ้าไม่ตั้ง OLLAMA_VISION_API_URL รูปสลิป Chat AI ใช้ OLLAMA_API_URL ชุดเดียวกับข้อความ
# ถ้า **ตั้ง** OLLAMA_VISION_API_URL: แชท UI อ่านสลิปด้วย Ollama ก่อน และจะ**ไม่**ส่งรูปไป Telegram (ไม่รอ Mavel) — ลบหรือไม่ตั้ง = อนุญาต fallback ไป Telegram ถ้า Ollama อ่านรูปล้ม
# OLLAMA_VISION_API_URL="http://127.0.0.1:8081/api/generate"
# --- แชท AI: อ่านสลิป → ยืนยันบันทึก (Kimi ก่อน แล้ว GLM-OCR รอง) ---
# ollama pull glm-ocr:latest
# รอบแรก: Kimi (หรือ OLLAMA_SLIP_VISION_PRIMARY_MODEL) ใช้ OLLAMA_API_URL หรือ OLLAMA_SLIP_VISION_PRIMARY_URL
# OLLAMA_SLIP_VISION_PRIMARY_URL="http://127.0.0.1:11434"
# OLLAMA_SLIP_VISION_PRIMARY_MODEL="kimi-k2.5:cloud"
# หลังอ่านสลิปจากแชท (แนบรูปแล้วส่ง): บันทึกลง Home Finance อัตโนมัติเมื่อมีวันที่+ยอด — ปิดด้วย PERSONAL_AI_SLIP_AUTOSAVE_FINANCE=0
# PERSONAL_AI_SLIP_AUTOSAVE_FINANCE=0

# OLLAMA_SLIP_SKIP_KIMI=1   # บังคับ GLM อย่างเดียว (ข้ามทั้ง NVIDIA + Ollama รอบแรก)
# รอง: GLM-OCR — ถ้าไม่ตั้ง: ใช้ OLLAMA_VISION_API_URL หรือ OLLAMA_API_URL แทน
# OLLAMA_GLM_OCR_URL="http://127.0.0.1:11434"
# OLLAMA_GLM_OCR_MODEL="glm-ocr:latest"

# --- NVIDIA API (อ่านสลิปรอบแรก — multimodal เหมือน POST /v1/chat/completions) ---
# ใส่คีย์ใน .env เท่านั้น ห้าม commit; ถ้าเคยรั่วในแชทให้หมุนคีย์ที่ NVIDIA
# NVIDIA_API_KEY="nvapi-..."
# NVIDIA_CHAT_COMPLETIONS_URL="https://integrate.api.nvidia.com/v1/chat/completions"
# NVIDIA_SLIP_VISION_MODEL="moonshotai/kimi-k2.5"
# รูปฝั่งแอปส่งเป็น JPEG เป็นหลัก — ถ้าใช้ mime อื่น (เช่น png) ตั้ง NVIDIA_SLIP_IMAGE_MIME=image/png
# NVIDIA_SLIP_IMAGE_MIME="image/jpeg"
# NVIDIA_SLIP_SKIP=1   # บังคับไม่เรียก NVIDIA (ใช้แค่ Ollama + GLM)

# --- อีเมลลิงก์รีเซ็ตรหัสผ่าน ---
# ลิงก์ในอีเมลใช้ origin จาก NEXT_PUBLIC_APP_URL → APP_URL → VERCEL_URL แล้วจึง Host จากคำขอ
# แบบที่ 1 (แนะนำ): ส่งจากบัญชี Google ด้วย Gmail SMTP + OAuth2
#   ใน Google Cloud Console → APIs & Services → OAuth client (แบบ Desktop หรือ Web) + เปิด Gmail API
#   สร้าง refresh token ด้วย scope: https://www.googleapis.com/auth/gmail.send
#   (โทเค็นนี้ต่างจากล็อกอิน Google ของผู้ใช้แอป — เป็นบัญชีผู้ส่งเท่านั้น)
# GMAIL_SENDER_EMAIL="yourcompany@gmail.com"
# GMAIL_OAUTH_REFRESH_TOKEN="1//0g..."
# ใช้ client เดียวกับล็อกอินได้ — หรือแยกเฉพาะอีเมล:
# GMAIL_OAUTH_CLIENT_ID=....apps.googleusercontent.com
# GMAIL_OAUTH_CLIENT_SECRET=GOCSPX-...
# แบบที่ 2: SMTP ทั่วไป (เช่น Gmail App Password: smtp.gmail.com + SMTP_USER + SMTP_PASS)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=yourcompany@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx
# SMTP_FROM="MAWELL Buffet <yourcompany@gmail.com>"
# ถ้าไม่ตั้งทั้ง OAuth และ SMTP_HOST → ไม่ส่งอีเมล (ลิงก์รีเซ็ตจะถูก log ที่เซิร์ฟเวอร์เท่านั้น)

# Melody / ชำระเงิน — HMAC-SHA256 ของ raw body เปรียบกับ header x-melody-signature
# MELODY_WEBHOOK_SECRET=
# ใช้ MQTT flow แบบ MelodyWebapp (ถ้าตั้ง MQTT_BROKER_URL)
# MQTT_BROKER_URL="mqtt://localhost:1883"
# โปรดักชัน MAWELL broker (TCP MQTT + มักใช้พอร์ตเดียวกับ WebSocket ที่ 4745)
# MQTT_BROKER_URL="mqtt://mawell.thddns.net:4745"
# NEXT_PUBLIC_MQTT_WS_URL="ws://mawell.thddns.net:4745"
# NEXT_PUBLIC_MQTT_BROKER_HOST="mawell.thddns.net"
# NEXT_PUBLIC_MQTT_BROKER_PORT_TCP="4745"
# NEXT_PUBLIC_MQTT_WSS_URL="wss://example.com:8084/mqtt"
# บังคับ webhook จาก broker — ตั้งค่าให้ตรง header x-mqtt-secret
# MQTT_WEBHOOK_SECRET=
# โมดูล MQTT ในแดชบอร์ด — ไม่ตั้งหรือ false = ซ่อน (ค่าเริ่มต้น)
# MQTT_SERVICE_ENABLED=false
# MQTT_TOPUP_ATTACH="V0"
# MQTT_BRANCH_TOPICS="V0,V1"

# อนุญาตจำลองชำระใน production (ไม่แนะนำ)
# ALLOW_MELODY_SIMULATE=true

# --- Telegram Bot (webhook) ---
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_API_URL="https://api.telegram.org/bot<TOKEN>"  # ถ้าไม่ตั้ง ระบบจะประกอบจาก TELEGRAM_BOT_TOKEN เอง
# TELEGRAM_WEBHOOK_SECRET=""  # ตั้งแล้วต้องส่ง header x-telegram-bot-api-secret-token ให้ตรง
# แชทปลายทางสำหรับส่งต่อรูปสลิปให้น้องมาเวล (ตัวจริง) — chat id เป็นตัวเลข
# แชทปลายทางสำหรับส่งรูปสลิปจาก Chat UI (ถ้าไม่ตั้ง จะใช้ TELEGRAM_MAVEL_FORWARD_CHAT_ID / TELEGRAM_FORWARD_SLIPS_TO_CHAT_ID)
# TELEGRAM_CHAT_UI_SLIP_CHAT_ID="8283294851"
# TELEGRAM_MAVEL_FORWARD_CHAT_ID="8283294851"
# ชื่อเดิม (รองรับย้อนหลัง)
# TELEGRAM_FORWARD_SLIPS_TO_CHAT_ID="8283294851"
# ชื่อบอทใน caption สลิปจาก Chat UI (ให้ Mavel ส่งผลกลับที่ @บอทนี้) — ค่าเริ่ม mawellltp_bot
# TELEGRAM_SLIP_REPLY_BOT_USERNAME="mawellltp_bot"
# ผลวิเคราะห์กลับ Chat UI: น้องมาเวล (หรือผู้ใดก็ได้) ต้อง **กด reply ต่อรูปที่บอทส่งในกลุ่ม** (ไม่ใช่ข้อความแยก) — webhook จะนำข้อความนั้นไปแสดงในแชทเว็บ
