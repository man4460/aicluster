# MySQL บนเครื่อง (แก้ user, password, พอร์ต ตามจริง)
# แอปรันบนเครื่องเดียวกับ DB → ใช้ localhost ได้ (อุปกรณ์อื่นใน WiFi เข้าแค่เว็บ ไม่ต่อ DB โดยตรง)
DATABASE_URL="mysql://root:YOUR_PASSWORD@localhost:3306/mawell_buffet"
AUTH_SECRET="replace-with-at-least-32-random-characters-here"
APP_URL="http://localhost:3000"

# --- เข้าสู่ระบบด้วย Google (OAuth 2.0) ---
# สร้าง OAuth Client แบบ Web ใน Google Cloud Console — ใส่ Authorized redirect URI:
#   http://localhost:3000/api/auth/google/callback
#   และ URL โปรดักชันจริง เช่น https://your-domain.com/api/auth/google/callback
# รัน migrate หลังเพิ่มฟิลด์ google_sub (ดู prisma/migrations/*user_google_oauth*)
# GOOGLE_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...
# หรือใส่ Client ID แบบสาธารณะ (ค่าเดียวกับบรรทัดบนได้) — ร่วมกับ GOOGLE_CLIENT_SECRET ด้านบน
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=....apps.googleusercontent.com

# --- เข้าจาก WiFi / LAN เดียวกัน ---
# รัน production (next start / PM2) แต่เปิดด้วย http://192.168.x.x → ต้องปิด Secure cookie ไม่งั้นล็อกอินไม่ติด
# COOKIE_SECURE=false
# โหมด dev: ถ้า IP ไม่อยู่ในช่วง 192.168 / 10.x ให้ระบุ host เอง (คั่นด้วย comma)
# ALLOWED_DEV_ORIGINS=192.168.1.88
# ลิงก์/QR ให้ตรงกับ URL ที่เปิดจริง (ถ้าเข้าจากมือถือด้วย IP ของ PC)
# NEXT_PUBLIC_APP_URL="http://192.168.1.88:3000"
# ลิงก์สาธารณะ / QR (ถ้าไม่ตั้ง จะใช้ APP_URL หรือ Host จาก request; บน Vercel มี VERCEL_URL)
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="MAWELL <noreply@example.com>"

# Melody / ชำระเงิน — HMAC-SHA256 ของ raw body เปรียบกับ header x-melody-signature
# MELODY_WEBHOOK_SECRET=
# ใช้ MQTT flow แบบ MelodyWebapp (ถ้าตั้ง MQTT_BROKER_URL)
# MQTT_BROKER_URL="mqtt://localhost:1883"
# โปรดักชัน MAWELL broker (TCP MQTT + มักใช้พอร์ตเดียวกับ WebSocket ที่ 4745)
# MQTT_BROKER_URL="mqtt://mawell.thddns.net:4745"
# NEXT_PUBLIC_MQTT_WS_URL="ws://mawell.thddns.net:4745"
# NEXT_PUBLIC_MQTT_BROKER_HOST="mawell.thddns.net"
# NEXT_PUBLIC_MQTT_BROKER_PORT_TCP="4745"
# NEXT_PUBLIC_MQTT_WSS_URL="wss://example.com:8084/mqtt"
# บังคับ webhook จาก broker — ตั้งค่าให้ตรง header x-mqtt-secret
# MQTT_WEBHOOK_SECRET=
# โมดูล MQTT ในแดชบอร์ด — ไม่ตั้งหรือ false = ซ่อน (ค่าเริ่มต้น)
# MQTT_SERVICE_ENABLED=false
# MQTT_TOPUP_ATTACH="V0"
# MQTT_BRANCH_TOPICS="V0,V1"

# อนุญาตจำลองชำระใน production (ไม่แนะนำ)
# ALLOW_MELODY_SIMULATE=true
