// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// engine แบบ library ทำงานกับ Next/Turbopack ได้ดีกว่า binary (binary runtime เรียก process.once ซึ่ง polyfill ของ bundler มักไม่มี)
generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum TopUpStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

/** ห้องแชท — ชุมชน (กระทู้) | ติดต่อแอดมิน */
enum ChatRoomKind {
  COMMUNITY
  ADMIN_SUPPORT
}

/** บทบาทข้อความในแชท AI ส่วนตัว */
enum PersonalChatMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum PersonalAiPlanStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum SubscriptionTier {
  NONE
  TIER_199
  TIER_299
  TIER_399
  TIER_499
  TIER_599
}

/** BUFFET = แพ็กเกจ/รายเดือน | DAILY = สายรายวัน */
enum SubscriptionType {
  BUFFET
  DAILY
}

/**
 * ผู้ใช้แพลตฟอร์ม MAWELL — ตาราง `User` (String/cuid) = ผู้ใช้ + Token/Buffet
 * สเปกเอกสารที่เรียกตาราง `users` + INT ใช้เป็นแนวคิดเทียบเท่า: ฟิลด์ subscription/tokens/last หักโทเคน อยู่ที่นี่
 */
model User {
  id                       String           @id @default(cuid())
  email                    String           @unique
  username                 String           @unique
  /** ว่างได้เมื่อสมัคร/เข้าสู่ระบบผ่าน Google เท่านั้น */
  passwordHash             String?
  /** OpenID subject จาก Google — ผูกบัญชีล็อกอิน Google */
  googleSub                String?          @unique @map("google_sub") @db.VarChar(191)
  role                     UserRole         @default(USER)
  resetToken               String?
  resetTokenExpires        DateTime?
  tokens                   Int              @default(0) @map("tokens")
  lastDeductionDate        DateTime?        @map("last_deduction_date")
  lastBuffetBillingMonth   String?          @map("last_buffet_billing_month") @db.VarChar(7)
  lastDormitoryTokenDate   DateTime?        @map("last_dormitory_token_date") @db.Date
  lastBarberTokenDate      DateTime?        @map("last_barber_token_date") @db.Date
  lastAttendanceTokenDate  DateTime?        @map("last_attendance_token_date") @db.Date
  lastVillageTokenDate     DateTime?        @map("last_village_token_date") @db.Date
  /** ถ้ามี = พนักงานใต้เจ้าของ — ใช้สิทธิ์/โทเคนของ employer */
  employerUserId           String?          @map("employer_user_id") @db.VarChar(191)
  employer                 User?            @relation("EmployerStaff", fields: [employerUserId], references: [id], onDelete: SetNull)
  staffMembers             User[]           @relation("EmployerStaff")
  /** ผู้แนะนำสมัคร (เบอร์ผู้แนะนำตอน register) */
  referredByUserId         String?          @map("referred_by_user_id") @db.VarChar(191)
  referredBy               User?            @relation("UserReferrals", fields: [referredByUserId], references: [id], onDelete: SetNull)
  referredUsers            User[]           @relation("UserReferrals")
  subscriptionTier         SubscriptionTier @default(NONE) @map("subscription_tier")
  subscriptionType         SubscriptionType @default(DAILY) @map("subscription_type")
  fullName                 String?          @db.VarChar(255)
  phone                    String?          @db.VarChar(64)
  address                  String?          @db.Text
  latitude                 Float?
  longitude                Float?
  avatarUrl                String?          @db.VarChar(512)
  telegramChatId           String?          @unique @map("telegram_chat_id") @db.VarChar(64)
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  chatMessages           ChatMessage[]
  chatThreadsAuthored    ChatThread[]
  personalChatSessions        PersonalChatSession[]
  personalChatMessages        PersonalChatMessage[]
  personalChatMavelSlipPendings PersonalChatMavelSlipPending[]
  personalAiNotes        PersonalAiNote[]
  personalAiPlans        PersonalAiPlan[]
  personalAiSlipRecords  PersonalAiSlipRecord[]
  topUpOrders            TopUpOrder[]
  dormitoryProfiles         DormitoryProfile[]
  dormitoryCostCategories   DormitoryCostCategory[]
  dormitoryCostEntries      DormitoryCostEntry[]
  barberShopProfiles     BarberShopProfile[]
  rooms                  Room[]
  barberPackages         BarberPackage[]
  barberCustomers        BarberCustomer[]
  barberSubscriptions    BarberCustomerSubscription[]
  barberServiceLogs      BarberServiceLog[]
  barberStylists         BarberStylist[]
  barberPortalStaffPings BarberPortalStaffPing[]
  barberBookings         BarberBooking[]
  barberCostCategories   BarberCostCategory[]
  barberCostEntries      BarberCostEntry[]
  attendanceSettings       AttendanceSettings[]
  attendanceLogsOwned      AttendanceLog[]           @relation("AttendanceOrg")
  attendanceLogsAsActor    AttendanceLog[]           @relation("AttendanceActor")
  attendanceRosterEntries  AttendanceRosterEntry[]
  attendanceLocations      AttendanceLocation[]
  homeFinanceEntries       HomeFinanceEntry[]
  homeFinanceSlipExtractions HomeFinanceSlipExtraction[]
  homeFinanceCategories    HomeFinanceCategory[]
  homeUtilityProfiles      HomeUtilityProfile[]
  homeVehicleProfiles      HomeVehicleProfile[]
  homeFinanceReminders     HomeFinanceReminder[]
  carWashPackages          CarWashPackage[]
  carWashBundles           CarWashBundle[]
  carWashVisits            CarWashVisit[]
  carWashComplaints        CarWashComplaint[]
  carWashCostCategories    CarWashCostCategory[]
  carWashCostEntries       CarWashCostEntry[]
  mqttTenantProfiles       MqttTenantProfile[]
  mqttCredentials          MqttCredential[]
  mqttAclRules             MqttAclRule[]
  mqttClientSessionLogs    MqttClientSessionLog[]
  mqttMessageStatDailies   MqttMessageStatDaily[]
  buildingPosCategories     BuildingPosCategory[]
  buildingPosMenuItems      BuildingPosMenuItem[]
  buildingPosOrders         BuildingPosOrder[]
  buildingPosStaffLinks     BuildingPosStaffLink[]
  buildingPosIngredients    BuildingPosIngredient[]
  buildingPosPurchaseOrders BuildingPosPurchaseOrder[]
  villageProfiles           VillageProfile[]           @relation("VillageProfileToUser")
  villageHouses             VillageHouse[]             @relation("VillageHouseToUser")
  villageCommonFeeRows      VillageCommonFeeRow[]      @relation("VillageFeeRowToUser")
  villageSlipSubmissions    VillageSlipSubmission[]    @relation("VillageSlipToUser")
  villageCostCategories     VillageCostCategory[]
  villageCostEntries        VillageCostEntry[]
  trialSessions            TrialSession[]
  parkingSites             ParkingSite[]
  laundryPackages          LaundryPackage[]
  laundryOrders            LaundryOrder[]
  openClawSyncRequests     OpenClawSyncRequest[]

  @@index([employerUserId])
  @@index([referredByUserId], map: "user_referred_by_idx")
}

model OpenClawSyncRequest {
  id         BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  ownerUserId String  @map("owner_user_id") @db.VarChar(191)
  owner      User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  source     String   @db.VarChar(40)
  requestId  String   @map("request_id") @db.VarChar(128)
  createdAt  DateTime @default(now()) @map("created_at")

  @@unique([ownerUserId, source, requestId], map: "openclaw_sync_req_owner_source_req_uniq")
  @@index([ownerUserId, createdAt], map: "openclaw_sync_req_owner_created_idx")
  @@map("openclaw_sync_requests")
}

/** ทดลองใช้โมดูล — แยกข้อมูล sandbox ใน DB เดียวกันด้วย trialSessionId บนแถวข้อมูล */
enum TrialSessionStatus {
  ACTIVE
  EXPIRED
}

model TrialSession {
  id        String             @id @default(cuid())
  userId    String             @map("user_id") @db.VarChar(191)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId  String             @map("module_id") @db.VarChar(191)
  module    AppModule          @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  status    TrialSessionStatus @default(ACTIVE) @map("status")
  expiresAt DateTime           @map("expires_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  @@index([userId, moduleId])
  @@index([expiresAt])
  @@map("trial_sessions")
}

/** แจ้งเตือนจาก Customer QR Portal (ลูกค้ากดแจ้งพนักงาน) */
model BarberPortalStaffPing {
  id               Int      @id @default(autoincrement())
  ownerUserId      String   @map("owner_id") @db.VarChar(191)
  owner            User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId   String   @default("prod") @map("trial_session_id") @db.VarChar(36)
  barberCustomerId Int?     @map("barber_customer_id")
  subscriptionId   Int?     @map("subscription_id")
  phoneMasked      String   @map("phone_masked") @db.VarChar(32)
  clientLatitude   Float?   @map("client_latitude")
  clientLongitude  Float?   @map("client_longitude")
  distanceMeters   Float?   @map("distance_meters")
  geoVerified      Boolean  @default(false) @map("geo_verified")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([ownerUserId, createdAt])
  @@map("barber_portal_staff_pings")
}

/** ช่างตัดผมในร้าน — ต่อเจ้าของร้าน (User แพลตฟอร์ม) */
model BarberStylist {
  id          Int      @id @default(autoincrement())
  ownerUserId String   @map("owner_id") @db.VarChar(191)
  owner       User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId String @default("prod") @map("trial_session_id") @db.VarChar(36)
  name        String   @db.VarChar(100)
  phone       String?  @db.VarChar(20)
  /** รูปโปรไฟล์ — path ใต้ public เช่น /uploads/barber-stylists/... */
  photoUrl    String?  @map("photo_url") @db.VarChar(512)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  subscriptionsSold BarberCustomerSubscription[] @relation("SubscriptionSoldByStylist")
  serviceLogs       BarberServiceLog[]

  @@index([ownerUserId])
  @@index([ownerUserId, isActive])
  @@index([ownerUserId, trialSessionId])
  @@map("barber_stylists")
}

model AppModule {
  id            String   @id @default(cuid())
  slug          String   @unique @db.VarChar(191)
  title         String   @db.VarChar(255)
  description   String?  @db.Text
  /** รูปการ์ดระบบ (path ใต้ public เช่น /uploads/module-cards/...) */
  cardImageUrl  String?  @map("card_image_url") @db.VarChar(512)
  groupId       Int      @map("group_id")
  sortOrder     Int      @default(0) @map("sort_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  trialSessions TrialSession[]

  @@index([groupId])
  @@index([isActive, sortOrder])
  @@map("module_list")
}

model ChatThread {
  id        String       @id @default(cuid())
  title     String       @db.VarChar(280)
  authorId  String
  author    User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  roomKind  ChatRoomKind
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  messages  ChatMessage[]

  @@index([roomKind, createdAt])
  @@index([authorId, roomKind])
}

model ChatMessage {
  id        String     @id @default(cuid())
  threadId  String
  thread    ChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  content   String     @db.VarChar(2000)
  createdAt DateTime   @default(now())

  @@index([threadId, createdAt])
  @@index([createdAt])
}

/**
 * แชท AI ส่วนตัวของผู้ใช้
 * - ผูกกับผู้ใช้ในตาราง User (users)
 * - 1 session มีหลายข้อความ
 */
model PersonalChatSession {
  id            String                @id @default(cuid())
  userId        String                @map("user_id") @db.VarChar(191)
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String?               @db.VarChar(280)
  assistantId   String?               @map("assistant_id") @db.VarChar(64)
  provider      String?               @db.VarChar(64)
  model         String?               @db.VarChar(128)
  lastMessageAt DateTime?             @map("last_message_at")
  /** ร่างรายการจากสลิปล่าสุด (รอผู้ใช้พิมพ์ยืนยันเพื่อบันทึกลง home finance) */
  pendingSlipDraft Json?              @map("pending_slip_draft")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")
  messages             PersonalChatMessage[]
  mavelSlipPendings    PersonalChatMavelSlipPending[]

  @@index([userId, updatedAt], map: "chat_sessions_user_updated_idx")
  @@index([userId, lastMessageAt], map: "chat_sessions_user_last_message_idx")
  @@map("chat_sessions")
}

/** ข้อความในแชท AI ส่วนตัว */
model PersonalChatMessage {
  id          String                  @id @default(cuid())
  sessionId   String                  @map("session_id")
  session     PersonalChatSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId      String                  @map("user_id") @db.VarChar(191)
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        PersonalChatMessageRole
  content     String                  @db.Text
  tokenCount  Int?                    @map("token_count")
  createdAt   DateTime                @default(now()) @map("created_at")

  @@index([sessionId, createdAt], map: "chat_messages_session_created_idx")
  @@index([userId, createdAt], map: "chat_messages_user_created_idx")
  @@map("chat_messages")
}

/**
 * รอรับข้อความวิเคราะห์สลิปจาก Mavel ในกลุ่ม Telegram แบบ reply ต่อรูปที่บอทส่งจาก Chat UI
 */
model PersonalChatMavelSlipPending {
  id             String              @id @default(cuid())
  userId         String              @map("user_id") @db.VarChar(191)
  user           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId      String              @map("session_id") @db.VarChar(191)
  session        PersonalChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  mavelChatId    String              @map("mavel_chat_id") @db.VarChar(32)
  mavelMessageId Int                 @map("mavel_message_id")
  createdAt      DateTime            @default(now()) @map("created_at")

  @@unique([mavelChatId, mavelMessageId], map: "mavel_slip_pending_chat_msg_uidx")
  @@index([sessionId], map: "mavel_slip_pending_session_idx")
  @@index([createdAt], map: "mavel_slip_pending_created_idx")
  @@map("chat_mavel_slip_pending")
}

/** บันทึกส่วนตัวของ AI assistant */
model PersonalAiNote {
  id                 String   @id @default(cuid())
  userId             String   @map("user_id") @db.VarChar(191)
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content            String   @db.Text
  tags               Json?
  externalSource     String?  @map("external_source") @db.VarChar(40)
  externalId         String?  @map("external_id") @db.VarChar(128)
  lastSyncedAt       DateTime? @map("last_synced_at")
  /** ซ่อนจากแถบสรุป Chat AI / digest รายวัน (ยังเก็บในระบบ — แก้ได้จากโมดัลโน้ต) */
  hiddenFromDigest Boolean  @default(false) @map("hidden_from_digest")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([userId, createdAt], map: "ai_notes_user_created_idx")
  @@index([userId, externalSource, externalId], map: "ai_notes_user_external_idx")
  @@map("ai_notes")
}

/** แผนงานส่วนตัวของผู้ใช้ */
model PersonalAiPlan {
  id        String               @id @default(cuid())
  userId    String               @map("user_id") @db.VarChar(191)
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String               @db.VarChar(200)
  steps     Json
  status    PersonalAiPlanStatus @default(TODO)
  dueDate   DateTime?            @map("due_date")
  externalSource String?         @map("external_source") @db.VarChar(40)
  externalId String?             @map("external_id") @db.VarChar(128)
  lastSyncedAt DateTime?         @map("last_synced_at")
  createdAt DateTime             @default(now()) @map("created_at")
  updatedAt DateTime             @updatedAt @map("updated_at")

  @@index([userId, createdAt], map: "ai_plans_user_created_idx")
  @@index([userId, status], map: "ai_plans_user_status_idx")
  @@index([userId, externalSource, externalId], map: "ai_plans_user_external_idx")
  @@map("ai_plans")
}

/** บันทึกผลอ่านสลิปจาก AI */
model PersonalAiSlipRecord {
  id         String   @id @default(cuid())
  userId     String   @map("user_id") @db.VarChar(191)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl   String   @map("image_url") @db.VarChar(2048)
  parsedData Json?    @map("parsed_data")
  amount     Decimal? @db.Decimal(12, 2)
  slipDate   DateTime? @map("slip_date")
  category   String?  @db.VarChar(120)
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([userId, createdAt], map: "ai_slips_user_created_idx")
  @@map("ai_slip_records")
}

model TopUpOrder {
  id             String      @id @default(cuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  planPriceKey   Int         @map("amountBaht")
  tokensToDeduct Int         @map("tokensToAdd")
  status         TopUpStatus @default(PENDING)
  externalRef    String?     @unique @db.VarChar(191)
  melodyMeta     Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([userId])
  @@index([status])
}

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
}

/** ข้อมูลแสดงบนใบเสร็จ / สลิป — แยก production (`prod`) กับ sandbox ทดลอง */
model DormitoryProfile {
  id               Int      @id @default(autoincrement())
  ownerUserId      String   @map("owner_id") @db.VarChar(191)
  owner            User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  /** `prod` = ข้อมูลจริง | cuid = ชุดทดลอง */
  trialSessionId   String   @default("prod") @map("trial_session_id") @db.VarChar(36)
  /** ชื่อหอพัก (แสดงบนสลิป) */
  displayName      String?  @map("display_name") @db.VarChar(200)
  /** โลโก้ เช่น /uploads/dorm-logos/... */
  logoUrl          String?  @map("logo_url") @db.VarChar(512)
  /** เลขประจำตัวผู้เสียภาษี */
  taxId            String?  @map("tax_id") @db.VarChar(30)
  /** ที่อยู่หอพัก */
  address          String?  @db.Text
  /** เบอร์โทรผู้ดูแล */
  caretakerPhone   String?  @map("caretaker_phone") @db.VarChar(32)
  /** ขนาดกระดาษเริ่มต้นเมื่อเปิดใบเสร็จ: SLIP_58 | SLIP_80 | A4 */
  defaultPaperSize String   @default("SLIP_58") @map("default_paper_size") @db.VarChar(16)
  /** เบอร์พร้อมเพย์ (เฉพาะตัวเลข 10 หลัก หรือ 081...) สำหรับ QR บนใบแจ้งหนี้ */
  promptPayPhone   String?  @map("prompt_pay_phone") @db.VarChar(20)
  /** ข้อความช่องทางชำระ (โอนธนาคาร ฯลฯ) แสดงบนใบแจ้งหนี้ */
  paymentChannelsNote String? @map("payment_channels_note") @db.Text
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([ownerUserId, trialSessionId])
  @@index([ownerUserId])
  @@map("dormitory_profiles")
}

/** ข้อมูลร้านตัดผม — โลโก้/ชื่อร้าน สำหรับป้าย QR และแสดงผลทั่วไป */
model BarberShopProfile {
  id           Int      @id @default(autoincrement())
  ownerUserId  String   @map("owner_id") @db.VarChar(191)
  owner        User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId String @default("prod") @map("trial_session_id") @db.VarChar(36)
  displayName  String?  @map("display_name") @db.VarChar(200)
  logoUrl      String?  @map("logo_url") @db.VarChar(512)
  taxId        String?  @map("tax_id") @db.VarChar(30)
  address      String?  @db.Text
  contactPhone String?  @map("contact_phone") @db.VarChar(32)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([ownerUserId, trialSessionId])
  @@index([ownerUserId])
  @@map("barber_shop_profiles")
}

/** ห้องพัก — เจ้าของข้อมูล = ผู้ใช้ MAWELL (owner_id → users.id) */
model Room {
  id           Int        @id @default(autoincrement())
  ownerUserId  String     @map("owner_id") @db.VarChar(191)
  owner        User       @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId String   @default("prod") @map("trial_session_id") @db.VarChar(36)
  roomNumber   String     @map("room_number") @db.VarChar(10)
  floor        Int
  roomType     String     @map("room_type") @db.VarChar(50)
  maxOccupants Int        @default(1) @map("max_occupants")
  basePrice    Decimal    @map("base_price") @db.Decimal(10, 2)
  status       RoomStatus @default(AVAILABLE)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  tenants      Tenant[]
  utilityBills UtilityBill[]

  @@unique([ownerUserId, roomNumber, trialSessionId])
  @@index([ownerUserId])
  @@map("rooms")
}

enum TenantStatus {
  ACTIVE
  MOVED_OUT
}

model Tenant {
  id           Int          @id @default(autoincrement())
  roomId       Int          @map("room_id")
  room         Room         @relation(fields: [roomId], references: [id], onDelete: Cascade)
  name         String       @db.VarChar(100)
  phone        String       @db.VarChar(20)
  idCard       String       @map("id_card") @db.VarChar(13)
  status       TenantStatus @default(ACTIVE)
  checkInDate  DateTime     @map("check_in_date") @db.Date
  checkOutDate DateTime?    @map("check_out_date") @db.Date
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  payments SplitBillPayment[]

  @@index([roomId])
  @@map("tenants")
}

/** บิลมิเตอร์น้ำ-ไฟระดับห้อง (ห้องละ 1 ชุดมิเตอร์ต่องวด) — ไม่ผูก tenant */
model UtilityBill {
  id                  Int      @id @default(autoincrement())
  roomId              Int      @map("room_id")
  room                Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  billingMonth        Int      @map("billing_month")
  billingYear         Int      @map("billing_year")
  waterMeterPrev      Int      @map("water_meter_prev")
  waterMeterCurr      Int      @map("water_meter_curr")
  electricMeterPrev   Int      @map("electric_meter_prev")
  electricMeterCurr   Int      @map("electric_meter_curr")
  waterPrice          Decimal  @map("water_price") @db.Decimal(10, 2)
  electricPrice       Decimal  @map("electric_price") @db.Decimal(10, 2)
  fixedFees           Json?    @map("fixed_fees")
  totalRoomAmount     Decimal  @map("total_room_amount") @db.Decimal(10, 2)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  payments SplitBillPayment[]

  @@unique([roomId, billingYear, billingMonth])
  @@index([roomId])
  @@map("utility_bills")
}

enum DormPaymentStatus {
  PENDING
  PAID
  OVERDUE
}

/** Split Bill รายคน — อ้างอิงบิลของห้อง (bill_id) + ผู้พัก (tenant_id) */
model SplitBillPayment {
  id              Int               @id @default(autoincrement())
  tenantId        Int               @map("tenant_id")
  billId          Int               @map("bill_id")
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bill            UtilityBill       @relation(fields: [billId], references: [id], onDelete: Cascade)
  amountToPay     Decimal           @map("amount_to_pay") @db.Decimal(10, 2)
  paymentStatus   DormPaymentStatus @default(PENDING) @map("payment_status")
  paidAt          DateTime?         @map("paid_at")
  receiptNumber   String?           @unique @map("receipt_number") @db.VarChar(32)
  note            String?           @db.VarChar(500)
  /** รูปสลิปที่ผู้พักอัปโหลด (ลิงก์สาธารณะ) หรือเจ้าของหออัปโหลดแทน */
  proofSlipUrl    String?           @map("proof_slip_url") @db.VarChar(512)
  proofUploadedAt DateTime?         @map("proof_uploaded_at")
  /** โทเคนสำหรับหน้า /pay/dorm/[token] อัปโหลดสลิปโดยไม่ล็อกอิน */
  publicProofToken String?          @unique @map("public_proof_token") @db.VarChar(64)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@unique([tenantId, billId])
  @@index([tenantId])
  @@index([billId])
  @@index([paymentStatus])
  @@map("payments")
}

/** หมวดต้นทุน/รายจ่ายหอพัก — โครงเดียวกับร้านตัดผม */
model DormitoryCostCategory {
  id             Int                  @id @default(autoincrement())
  ownerUserId    String               @map("owner_id") @db.VarChar(191)
  owner          User                 @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId String               @default("prod") @map("trial_session_id") @db.VarChar(36)
  name           String               @db.VarChar(120)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  entries        DormitoryCostEntry[]

  @@index([ownerUserId, trialSessionId], map: "dorm_cost_cat_owner_trial_idx")
  @@map("dormitory_cost_categories")
}

model DormitoryCostEntry {
  id             Int                   @id @default(autoincrement())
  ownerUserId    String                @map("owner_id") @db.VarChar(191)
  owner          User                  @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId String                @default("prod") @map("trial_session_id") @db.VarChar(36)
  categoryId     Int                   @map("category_id")
  category       DormitoryCostCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  spentAt        DateTime              @map("spent_at")
  amount         Int
  itemLabel      String                @default("") @map("item_label") @db.VarChar(200)
  note           String                @default("") @map("note") @db.VarChar(500)
  slipPhotoUrl   String                @default("") @map("slip_photo_url") @db.VarChar(512)
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")

  @@index([ownerUserId, trialSessionId, spentAt], map: "dorm_cost_ent_owner_trial_spent_idx")
  @@map("dormitory_cost_entries")
}

// --- Barber / ร้านตัดผม (กลุ่ม 1) ---

enum BarberSubscriptionStatus {
  ACTIVE
  EXHAUSTED
  CANCELLED
}

enum BarberVisitType {
  PACKAGE_USE
  CASH_WALK_IN
}

/** สถานะการจองคิว (เจ้าของร้านเป็นผู้บันทึก) */
enum BarberBookingStatus {
  SCHEDULED
  ARRIVED
  NO_SHOW
  CANCELLED
}

/** แพ็กเกจ/โปรโมชั่น (เช่น ตัด 10 ครั้ง 1,200 บ.) — ต่อเจ้าของร้าน */
model BarberPackage {
  id            Int      @id @default(autoincrement())
  ownerUserId   String   @map("owner_id") @db.VarChar(191)
  owner         User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId String  @default("prod") @map("trial_session_id") @db.VarChar(36)
  name          String   @db.VarChar(191)
  price         Decimal  @db.Decimal(10, 2)
  totalSessions Int      @map("total_sessions")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  subscriptions BarberCustomerSubscription[]

  @@index([ownerUserId])
  @@index([ownerUserId, trialSessionId])
  @@map("barber_packages")
}

/** ลูกค้าร้าน (ค้นด้วยเบอร์) — ไม่ใช่ User แพลตฟอร์ม */
model BarberCustomer {
  id           Int      @id @default(autoincrement())
  ownerUserId  String   @map("owner_id") @db.VarChar(191)
  owner        User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId String @default("prod") @map("trial_session_id") @db.VarChar(36)
  phone        String   @db.VarChar(20)
  name         String?  @db.VarChar(100)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  subscriptions BarberCustomerSubscription[]
  serviceLogs   BarberServiceLog[]
  bookings      BarberBooking[]

  @@unique([ownerUserId, phone, trialSessionId])
  @@index([ownerUserId])
  @@map("barber_customers")
}

/** จองคิวล่วงหน้า — ผูกเบอร์/ลูกค้าในระบบได้ */
model BarberBooking {
  id               Int                  @id @default(autoincrement())
  ownerUserId      String               @map("owner_id") @db.VarChar(191)
  owner            User                 @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId   String               @default("prod") @map("trial_session_id") @db.VarChar(36)
  barberCustomerId Int?                 @map("barber_customer_id")
  customer         BarberCustomer?      @relation(fields: [barberCustomerId], references: [id], onDelete: SetNull)
  phone            String               @map("phone") @db.VarChar(20)
  customerName     String?              @map("customer_name") @db.VarChar(100)
  scheduledAt      DateTime             @map("scheduled_at")
  status           BarberBookingStatus  @default(SCHEDULED) @map("status")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  @@index([ownerUserId, scheduledAt])
  @@index([ownerUserId, trialSessionId])
  @@map("barber_bookings")
}

/**
 * สมาชิกแพ็กเกจ — `barber_customer_id` = ลูกค้าร้าน (สเปกเอกสาร user_id ใช้ความหมายเดียวกับลูกค้าในระบบร้าน)
 */
model BarberCustomerSubscription {
  id                Int                      @id @default(autoincrement())
  ownerUserId       String                   @map("owner_id") @db.VarChar(191)
  owner             User                     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId    String                   @default("prod") @map("trial_session_id") @db.VarChar(36)
  barberCustomerId  Int                      @map("barber_customer_id")
  customer          BarberCustomer           @relation(fields: [barberCustomerId], references: [id], onDelete: Cascade)
  packageId         Int                      @map("package_id")
  package           BarberPackage            @relation(fields: [packageId], references: [id], onDelete: Restrict)
  /** ช่างที่บันทึกการขายแพ็ก (ถ้ามี) */
  soldByStylistId   Int?                     @map("sold_by_stylist_id")
  soldByStylist     BarberStylist?           @relation("SubscriptionSoldByStylist", fields: [soldByStylistId], references: [id], onDelete: SetNull)
  remainingSessions Int                      @map("remaining_sessions")
  status            BarberSubscriptionStatus @default(ACTIVE)
  /** รูปสลิปตอนขายแพ็ก (ถ้ามี) */
  saleReceiptImageUrl String?                @map("sale_receipt_image_url") @db.VarChar(512)
  createdAt         DateTime                 @default(now()) @map("created_at")
  updatedAt         DateTime                 @updatedAt @map("updated_at")

  serviceLogs BarberServiceLog[]

  @@index([ownerUserId])
  @@index([barberCustomerId])
  @@index([packageId])
  @@index([soldByStylistId])
  @@index([ownerUserId, trialSessionId])
  @@map("customer_subscriptions")
}

/** ประวัติการเข้าใช้ / หักครั้ง / เงินสด */
model BarberServiceLog {
  id               Int                           @id @default(autoincrement())
  ownerUserId      String                        @map("owner_id") @db.VarChar(191)
  owner            User                          @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId   String                        @default("prod") @map("trial_session_id") @db.VarChar(36)
  subscriptionId   Int?                          @map("subscription_id")
  subscription     BarberCustomerSubscription?   @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  barberCustomerId Int                           @map("barber_customer_id")
  customer         BarberCustomer                @relation(fields: [barberCustomerId], references: [id], onDelete: Cascade)
  visitType        BarberVisitType               @map("visit_type")
  /** ช่างที่บันทึกเช็คอิน (ถ้ามี) */
  stylistId        Int?                          @map("stylist_id")
  stylist          BarberStylist?                @relation(fields: [stylistId], references: [id], onDelete: SetNull)
  /** บันทึกเฉพาะ walk-in เงินสด — ใช้คำนวณรายได้ในประวัติ */
  amountBaht       Decimal?                      @map("amount_baht") @db.Decimal(10, 2)
  /** รูปบิล/สลิป walk-in เงินสด (ถ้ามี) */
  receiptImageUrl  String?                       @map("receipt_image_url") @db.VarChar(512)
  note             String?                       @db.VarChar(255)
  createdAt        DateTime                      @default(now()) @map("created_at")

  @@index([ownerUserId, createdAt])
  @@index([ownerUserId, trialSessionId])
  @@index([barberCustomerId])
  @@index([stylistId])
  @@map("barber_service_logs")
}

/** หมวดต้นทุนร้านตัดผม */
model BarberCostCategory {
  id             Int                @id @default(autoincrement())
  ownerUserId    String             @map("owner_id") @db.VarChar(191)
  owner          User               @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId String             @default("prod") @map("trial_session_id") @db.VarChar(36)
  name           String             @db.VarChar(120)
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  entries        BarberCostEntry[]

  @@index([ownerUserId, trialSessionId], map: "barber_cost_cat_owner_trial_idx")
  @@map("barber_cost_categories")
}

/** รายการจ่ายต้นทุนร้านตัดผม */
model BarberCostEntry {
  id             Int                 @id @default(autoincrement())
  ownerUserId    String              @map("owner_id") @db.VarChar(191)
  owner          User                @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId String              @default("prod") @map("trial_session_id") @db.VarChar(36)
  categoryId     Int                 @map("category_id")
  category       BarberCostCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  spentAt        DateTime            @map("spent_at")
  amount         Int
  itemLabel      String              @default("") @map("item_label") @db.VarChar(200)
  note           String              @default("") @db.VarChar(500)
  slipPhotoUrl   String              @default("") @map("slip_photo_url") @db.VarChar(512)
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  @@index([ownerUserId, trialSessionId, spentAt], map: "barber_cost_ent_owner_trial_spent_idx")
  @@map("barber_cost_entries")
}

// --- Smart Attendance / เช็คอินอัจฉริยะ (กลุ่ม 1) ---

enum AttendanceSummaryStatus {
  AWAITING_CHECKOUT
  ON_TIME
  LATE
  EARLY_LEAVE
  LATE_AND_EARLY
}

/** ผู้เช็คผ่านหน้าสาธารณะ — พนักงานในรายชื่อ vs บุคคลภายนอก */
enum AttendancePublicVisitorKind {
  ROSTER_STAFF
  EXTERNAL_GUEST
}

enum HomeFinanceEntryType {
  INCOME
  EXPENSE
}

enum HomeUtilityType {
  ELECTRIC
  WATER
}

enum HomeVehicleType {
  CAR
  MOTORCYCLE
}

enum HomeFinanceSlipExtractionStatus {
  SAVED
  NEEDS_REVIEW
  FAILED
  DUPLICATE
}

enum SystemActivityAction {
  CREATE
  UPDATE
  UPSERT
  DELETE
  CREATE_MANY
  UPDATE_MANY
  DELETE_MANY
}

/** ตั้งค่าเขตเวลา + จุดเช็คอิน — ต่อเจ้าขององค์กร (owner user) */
model AttendanceSettings {
  id                   Int      @id @default(autoincrement())
  ownerUserId          String   @map("owner_id") @db.VarChar(191)
  owner                User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  /** `prod` = ข้อมูลจริง | cuid = ชุดทดลอง */
  trialSessionId       String   @default("prod") @map("trial_session_id") @db.VarChar(36)
  /** เวลาเริ่มกะ รูปแบบ HH:mm (เวลาไทย) */
  shiftStartTime       String   @default("09:00") @map("shift_start_time") @db.VarChar(5)
  shiftEndTime         String   @default("18:00") @map("shift_end_time") @db.VarChar(5)
  allowedLocationLat   Float    @map("allowed_location_lat")
  allowedLocationLng   Float    @map("allowed_location_lng")
  radiusMeters         Int      @default(120) @map("radius_meters")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@unique([ownerUserId, trialSessionId], map: "atset_owner_trial_uidx")
  @@index([ownerUserId], map: "atset_owner_id_idx")
  @@map("attendance_settings")
}

/** โลเคชันจุดเช็ค (หลายจุดตามแพ็กเกจ) — กะสูงสุด 5 ต่อจุด */
model AttendanceLocation {
  id                 Int               @id @default(autoincrement())
  ownerUserId        String            @map("owner_id") @db.VarChar(191)
  owner              User              @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId     String            @default("prod") @map("trial_session_id") @db.VarChar(36)
  name               String            @default("จุดเช็ค") @db.VarChar(80)
  allowedLocationLat Float             @map("allowed_location_lat")
  allowedLocationLng Float             @map("allowed_location_lng")
  radiusMeters       Int               @default(120) @map("radius_meters")
  sortOrder          Int               @default(0) @map("sort_order")
  shifts             AttendanceShift[]
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  @@index([ownerUserId, trialSessionId, sortOrder], map: "aloc_owner_trial_sort_idx")
  @@index([ownerUserId], map: "aloc_owner_id_idx")
  @@map("attendance_locations")
}

model AttendanceShift {
  id         Int                @id @default(autoincrement())
  locationId Int                @map("location_id")
  location   AttendanceLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)
  startTime  String             @map("start_time") @db.VarChar(5)
  endTime    String             @map("end_time") @db.VarChar(5)
  sortOrder  Int                @default(0) @map("sort_order")
  createdAt  DateTime           @default(now()) @map("created_at")
  updatedAt  DateTime           @updatedAt @map("updated_at")

  @@index([locationId, sortOrder])
  @@map("attendance_shifts")
}

/** รายชื่อพนักงานสำหรับเช็คผ่าน QR/ลิงก์สาธารณะ — ยืนยันด้วยเบอร์ */
model AttendanceRosterEntry {
  id          Int      @id @default(autoincrement())
  ownerUserId String   @map("owner_id") @db.VarChar(191)
  owner       User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId String @default("prod") @map("trial_session_id") @db.VarChar(36)
  displayName String   @map("display_name") @db.VarChar(100)
  phone       String   @map("phone") @db.VarChar(20)
  isActive    Boolean  @default(true) @map("is_active")
  /** ลำดับกะในโลเคชัน (0 = กะแรก ตาม sort_order) สูงสุด 4 ถ้ามี 5 กะ */
  rosterShiftIndex Int @default(0) @map("roster_shift_index")
  /** รูปโปรไฟล์รายชื่อ (path ใต้ public เช่น /uploads/attendance-roster/...) */
  photoUrl    String?  @map("photo_url") @db.VarChar(512)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([ownerUserId, phone, trialSessionId])
  @@index([ownerUserId, trialSessionId, isActive])
  @@map("attendance_roster_entries")
}

/** บันทึกเช็คเข้า-ออก — actor = User แพลตฟอร์ม หรือ guest ผ่านเบอร์ */
model AttendanceLog {
  id              Int                      @id @default(autoincrement())
  ownerUserId     String                   @map("owner_id") @db.VarChar(191)
  owner           User                     @relation("AttendanceOrg", fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId  String                   @default("prod") @map("trial_session_id") @db.VarChar(36)
  actorUserId     String?                  @map("actor_user_id") @db.VarChar(191)
  actor           User?                    @relation("AttendanceActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  guestPhone      String?                      @map("guest_phone") @db.VarChar(20)
  guestName       String?                      @map("guest_name") @db.VarChar(100)
  /** ใช้เมื่อเช็คผ่านลิงก์สาธารณะ — แยกพนักงานในรายชื่อ vs บุคคลภายนอก */
  publicVisitorKind AttendancePublicVisitorKind? @map("public_visitor_kind")
  checkInTime     DateTime?                @map("check_in_time")
  checkOutTime    DateTime?                @map("check_out_time")
  checkInLat      Float?                   @map("check_in_lat")
  checkInLng      Float?                   @map("check_in_lng")
  checkOutLat     Float?                   @map("check_out_lat")
  checkOutLng     Float?                   @map("check_out_lng")
  status          AttendanceSummaryStatus  @default(AWAITING_CHECKOUT) @map("status")
  lateCheckIn     Boolean                  @default(false) @map("late_check_in")
  earlyCheckOut   Boolean                  @default(false) @map("early_check_out")
  /** รูปใบหน้าตอนเช็คเข้า (ลิงก์ใน public/uploads) — บังคับถ่ายก่อนเช็คเข้า */
  checkInFacePhotoUrl String?              @map("check_in_face_photo_url") @db.VarChar(512)
  /** กะที่ใช้คำนวณมาสาย/ออกก่อนเวลา ณ เวลาเช็คเข้า (ลำดับในโลเคชัน) */
  appliedShiftIndex Int?                   @map("applied_shift_index")
  note            String?                  @db.VarChar(500)
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  @@index([ownerUserId, trialSessionId, checkInTime], map: "alog_owner_trial_in_idx")
  @@index([ownerUserId, trialSessionId, guestPhone], map: "alog_owner_trial_phone_idx")
  @@index([ownerUserId], map: "alog_owner_id_idx")
  @@index([actorUserId])
  @@map("attendance_logs")
}

/** รายรับ-รายจ่ายในบ้าน/ร้าน (กลุ่ม 1) */
model HomeFinanceEntry {
  id               Int                 @id @default(autoincrement())
  ownerUserId      String              @map("owner_id") @db.VarChar(191)
  owner            User                @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  entryDate        DateTime            @map("entry_date") @db.Date
  type             HomeFinanceEntryType
  categoryKey      String              @map("category_key") @db.VarChar(64)
  categoryLabel    String              @map("category_label") @db.VarChar(100)
  title            String              @db.VarChar(160)
  amount           Decimal             @db.Decimal(12, 2)
  dueDate          DateTime?           @map("due_date") @db.Date
  billNumber       String?             @map("bill_number") @db.VarChar(100)
  vehicleType      String?             @map("vehicle_type") @db.VarChar(40)
  serviceCenter    String?             @map("service_center") @db.VarChar(160)
  paymentMethod    String?             @map("payment_method") @db.VarChar(40)
