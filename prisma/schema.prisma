  imageUrl       String   @default("") @map("image_url") @db.VarChar(512)
  sortOrder      Int      @default(100) @map("sort_order")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([ownerUserId, trialSessionId, sortOrder], map: "bpos_cat_owner_trial_sort_idx")
  @@index([ownerUserId], map: "bpos_cat_owner_idx")
  @@map("building_pos_categories")
}

model BuildingPosMenuItem {
  id             Int      @id @default(autoincrement())
  ownerUserId    String   @map("owner_id") @db.VarChar(191)
  owner          User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId String   @default("prod") @map("trial_session_id") @db.VarChar(36)
  categoryId     Int      @map("category_id")
  name           String   @db.VarChar(160)
  imageUrl       String   @default("") @map("image_url") @db.VarChar(512)
  price          Int
  description    String   @default("") @db.VarChar(800)
  isActive       Boolean  @default(true) @map("is_active")
  isFeatured     Boolean  @default(false) @map("is_featured")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([ownerUserId, trialSessionId, categoryId], map: "bpos_menu_owner_trial_cat_idx")
  @@index([ownerUserId], map: "bpos_menu_owner_idx")
  @@map("building_pos_menu_items")
}

model BuildingPosOrder {
  id             Int      @id @default(autoincrement())
  ownerUserId    String   @map("owner_id") @db.VarChar(191)
  owner          User     @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId String   @default("prod") @map("trial_session_id") @db.VarChar(36)
  customerName   String   @default("") @map("customer_name") @db.VarChar(160)
  tableNo        String   @default("") @map("table_no") @db.VarChar(40)
  status         String   @db.VarChar(24)
  itemsJson      Json     @map("items_json")
  totalAmount    Int      @default(0) @map("total_amount")
  note           String   @default("") @db.VarChar(1000)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([ownerUserId, trialSessionId, createdAt], map: "bpos_order_owner_trial_created_idx")
  @@index([ownerUserId], map: "bpos_order_owner_idx")
  @@map("building_pos_orders")
}

enum VillageFeeRowStatus {
  PENDING
  PARTIAL
  PAID
  WAIVED
}

enum VillageSlipStatus {
  PENDING
  APPROVED
  REJECTED
}

/** รอบเรียกเก็บค่าส่วนกลางต่อหลัง — อัตราในระบบยังคิดเป็นบาท/เดือน แล้วคูณตามรอบ */
enum VillageHouseFeeCycle {
  MONTHLY
  SEMI_ANNUAL
  ANNUAL
}

/** โปรไฟล์หมู่บ้าน / นิติ — ตั้งค่าค่าส่วนกลางเริ่มต้น */
model VillageProfile {
  id                   Int      @id @default(autoincrement())
  ownerUserId          String   @map("owner_id") @db.VarChar(191)
  owner                User     @relation("VillageProfileToUser", fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId       String   @default("prod") @map("trial_session_id") @db.VarChar(36)
  displayName          String?  @map("display_name") @db.VarChar(200)
  address              String?  @db.Text
  contactPhone         String?  @map("contact_phone") @db.VarChar(32)
  promptPayPhone       String?  @map("prompt_pay_phone") @db.VarChar(20)
  paymentChannelsNote  String?  @map("payment_channels_note") @db.Text
  /** ค่าส่วนกลางมาตรฐานต่อเดือน (บาท) */
  defaultMonthlyFee    Int      @default(0) @map("default_monthly_fee")
  /** วันครบกำหนดชำระของแต่ละเดือน (1–28) */
  dueDayOfMonth        Int      @default(5) @map("due_day_of_month")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@unique([ownerUserId, trialSessionId], map: "vprof_owner_trial_uniq")
  @@index([ownerUserId], map: "vprof_owner_idx")
  @@map("village_profiles")
}

/** แปลง/บ้านในโครงการ */
model VillageHouse {
  id                   Int      @id @default(autoincrement())
  ownerUserId          String   @map("owner_id") @db.VarChar(191)
  owner                User     @relation("VillageHouseToUser", fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId       String   @default("prod") @map("trial_session_id") @db.VarChar(36)
  houseNo              String   @map("house_no") @db.VarChar(120)
  plotLabel            String?  @map("plot_label") @db.VarChar(80)
  ownerName            String?  @map("owner_name") @db.VarChar(200)
  phone                String?  @db.VarChar(32)
  /** null = ใช้ defaultMonthlyFee จากโปรไฟล์ */
  monthlyFeeOverride   Int?     @map("monthly_fee_override")
  /** รายเดือน = ทุกเดือน | รายหกเดือน = ม.ค.+ก.ค. (6×อัตรา/เดือน) | รายปี = ม.ค. (12×) */
  feeCycle             VillageHouseFeeCycle @default(MONTHLY) @map("fee_cycle")
  isActive             Boolean  @default(true) @map("is_active")
  sortOrder            Int      @default(0) @map("sort_order")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  residents            VillageResident[]
  feeRows              VillageCommonFeeRow[]
  slips                VillageSlipSubmission[]

  @@unique([ownerUserId, trialSessionId, houseNo], map: "vhouse_owner_trial_no_uniq")
  @@index([ownerUserId, trialSessionId, sortOrder], map: "vhouse_owner_trial_sort_idx")
  @@index([ownerUserId], map: "vhouse_owner_idx")
  @@map("village_houses")
}

model VillageResident {
  id        Int          @id @default(autoincrement())
  houseId   Int          @map("house_id")
  house     VillageHouse @relation(fields: [houseId], references: [id], onDelete: Cascade)
  name      String       @db.VarChar(120)
  phone     String?      @db.VarChar(32)
  note      String?      @db.VarChar(200)
  isPrimary Boolean      @default(false) @map("is_primary")
  isActive  Boolean      @default(true) @map("is_active")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  @@index([houseId], map: "vres_house_idx")
  @@map("village_residents")
}

/** ค่าส่วนกลางรายบ้านต่อเดือน (YYYY-MM) */
model VillageCommonFeeRow {
  id             Int                  @id @default(autoincrement())
  ownerUserId    String               @map("owner_id") @db.VarChar(191)
  owner          User                 @relation("VillageFeeRowToUser", fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId String               @default("prod") @map("trial_session_id") @db.VarChar(36)
  houseId        Int                  @map("house_id")
  house          VillageHouse         @relation(fields: [houseId], references: [id], onDelete: Cascade)
  yearMonth      String               @map("year_month") @db.VarChar(7)
  amountDue      Int                  @map("amount_due")
  amountPaid     Int                  @default(0) @map("amount_paid")
  status         VillageFeeRowStatus  @default(PENDING) @map("status")
  note           String?              @db.VarChar(500)
  paidAt         DateTime?            @map("paid_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  slips          VillageSlipSubmission[]

  @@unique([ownerUserId, trialSessionId, houseId, yearMonth], map: "vfee_owner_trial_house_ym_uniq")
  @@index([ownerUserId, trialSessionId, yearMonth], map: "vfee_owner_trial_ym_idx")
  @@index([ownerUserId], map: "vfee_owner_idx")
  @@map("village_common_fee_rows")
}

/** สลิปโอน — รอตรวจ / อนุมัติ */
model VillageSlipSubmission {
  id             Int                  @id @default(autoincrement())
  ownerUserId    String               @map("owner_id") @db.VarChar(191)
  owner          User                 @relation("VillageSlipToUser", fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId String               @default("prod") @map("trial_session_id") @db.VarChar(36)
  houseId        Int                  @map("house_id")
  house          VillageHouse         @relation(fields: [houseId], references: [id], onDelete: Cascade)
  feeRowId       Int?                 @map("fee_row_id")
  feeRow         VillageCommonFeeRow? @relation(fields: [feeRowId], references: [id], onDelete: SetNull)
  yearMonth      String               @map("year_month") @db.VarChar(7)
  amount         Int
  slipImageUrl   String               @map("slip_image_url") @db.VarChar(512)
  status         VillageSlipStatus    @default(PENDING) @map("status")
  reviewerNote   String?              @map("reviewer_note") @db.VarChar(500)
  submittedAt    DateTime             @default(now()) @map("submitted_at")
  reviewedAt     DateTime?            @map("reviewed_at")

  @@index([ownerUserId, trialSessionId, status], map: "vslip_owner_trial_status_idx")
  @@index([ownerUserId, trialSessionId, yearMonth], map: "vslip_owner_trial_ym_idx")
  @@index([feeRowId], map: "vslip_fee_row_idx")
  @@map("village_slip_submissions")
}

/** โหมดคิดเงินที่จอดรถ — รายชั่วโมง (ปัดขึ้น) หรือ เหมารายวันปฏิทิน (Bangkok) */
enum ParkingPricingMode {
  HOURLY
  DAILY
}

enum ParkingSessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

/** ลานจอดต่อเจ้าของ — ตั้งราคาและโหมดคิดเงิน */
model ParkingSite {
  id               Int                @id @default(autoincrement())
  ownerUserId      String             @map("owner_user_id") @db.VarChar(191)
  owner            User               @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  trialSessionId   String             @default("prod") @map("trial_session_id") @db.VarChar(36)
  name             String             @db.VarChar(120)
  pricingMode      ParkingPricingMode @default(HOURLY) @map("pricing_mode")
  hourlyRateBaht   Decimal?           @map("hourly_rate_baht") @db.Decimal(10, 2)
  dailyRateBaht    Decimal?           @map("daily_rate_baht") @db.Decimal(10, 2)
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  spots ParkingSpot[]

  @@unique([ownerUserId, name, trialSessionId], map: "parking_site_owner_name_trial_uniq")
  @@index([ownerUserId], map: "parking_site_owner_idx")
  @@map("parking_sites")
}

/** ช่องจอด — QR เช็คอินรายช่อง (check_in_token) */
model ParkingSpot {
  id           Int         @id @default(autoincrement())
  siteId       Int         @map("site_id")
  site         ParkingSite @relation(fields: [siteId], references: [id], onDelete: Cascade)
  spotCode     String      @map("spot_code") @db.VarChar(24)
  zoneLabel    String?     @map("zone_label") @db.VarChar(80)
  sortFloor    Int         @default(0) @map("sort_floor")
  sortOrder    Int         @default(0) @map("sort_order")
  checkInToken String      @unique @map("check_in_token") @db.VarChar(64)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  sessions ParkingSession[]

  @@unique([siteId, spotCode], map: "parking_spot_site_code_uniq")
  @@index([siteId], map: "parking_spot_site_idx")
  @@map("parking_spots")
}

/** รอบการจอด — เช็คอิน/เอาออก + หมายเหตุรับส่ง */
model ParkingSession {
  id              Int                  @id @default(autoincrement())
  spotId          Int                  @map("spot_id")
  spot            ParkingSpot          @relation(fields: [spotId], references: [id], onDelete: Cascade)
  status          ParkingSessionStatus @default(ACTIVE)
  checkInAt       DateTime             @map("check_in_at")
  checkOutAt      DateTime?            @map("check_out_at")
  licensePlate    String               @map("license_plate") @db.VarChar(24)
  customerName    String?              @map("customer_name") @db.VarChar(100)
  customerPhone   String?              @map("customer_phone") @db.VarChar(32)
  selfCheckIn     Boolean              @default(false) @map("self_check_in")
  pricingMode     ParkingPricingMode   @map("pricing_mode")
  hourlyRateSnap  Decimal?             @map("hourly_rate_snap") @db.Decimal(10, 2)
  dailyRateSnap   Decimal?             @map("daily_rate_snap") @db.Decimal(10, 2)
  billedUnits     Int?                 @map("billed_units")
  amountDueBaht   Decimal?             @map("amount_due_baht") @db.Decimal(10, 2)
  amountPaidBaht  Decimal?             @map("amount_paid_baht") @db.Decimal(10, 2)
  internalNote    String?              @map("internal_note") @db.Text
  shuttleFrom     String?              @map("shuttle_from") @db.VarChar(255)
  shuttleTo       String?              @map("shuttle_to") @db.VarChar(255)
  shuttleNote     String?              @map("shuttle_note") @db.Text
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  @@index([spotId, status], map: "parking_sess_spot_status_idx")
  @@index([checkInAt], map: "parking_sess_checkin_idx")
  @@index([licensePlate], map: "parking_sess_plate_idx")
  @@map("parking_sessions")
}

/** Log กลางทั้งระบบ (immutable) สำหรับตรวจสอบการจัดการข้อมูล */
model SystemActivityLog {
  id          BigInt               @id @default(autoincrement()) @db.UnsignedBigInt
  actorUserId String?              @map("actor_user_id") @db.VarChar(191)
  action      SystemActivityAction @map("action")
  modelName   String               @map("model_name") @db.VarChar(120)
  payload     Json?                @map("payload")
  createdAt   DateTime             @default(now()) @map("created_at")
  expiresAt   DateTime             @map("expires_at")

  @@index([createdAt])
  @@index([expiresAt])
  @@index([actorUserId, createdAt])
  @@index([modelName, createdAt])
  @@map("system_activity_logs")
}
