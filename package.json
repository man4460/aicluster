{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "mawell-deploy": "./bin/mawell-deploy"
  },
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "dev:webpack": "next dev -H 0.0.0.0 --webpack",
    "dev:clean": "npx --yes kill-port 3000 3001 3456 3457 && npx --yes rimraf@6 .next && next dev -p 3000 -H 0.0.0.0",
    "build": "prisma generate && next build",
    "build:pm2:prod": "npm run build && pm2 restart mawell-serve",
    "watch:build": "chokidar \"src/**/*\" \"public/**/*\" \"prisma/schema.prisma\" \"next.config.ts\" \"postcss.config.mjs\" \"package.json\" -c \"npm run build\" -d 12000 --silent",
    "watch:pm2:prod": "chokidar \"src/**/*\" \"public/**/*\" \"prisma/schema.prisma\" \"next.config.ts\" \"postcss.config.mjs\" \"package.json\" \"ecosystem.config.cjs\" -c \"npm run build:pm2:prod\" -d 12000 --silent",
    "start": "next start -H 0.0.0.0",
    "lint": "eslint",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "postinstall": "prisma generate",
    "pm2:dev": "pm2 start ecosystem.config.cjs --only mawell-dev",
    "pm2:prod": "pm2 start ecosystem.config.cjs --only mawell-serve",
    "pm2:prod:watch": "npm run pm2:prod && npm run watch:pm2:prod",
    "pm2:stop": "pm2 stop mawell-dev mawell-serve",
    "pm2:restart": "pm2 restart mawell-dev",
    "pm2:logs": "pm2 logs mawell-dev",
    "pm2:delete": "pm2 delete mawell-dev mawell-serve",
    "deploy": "bash scripts/deploy.sh",
    "link:cli": "npm link --ignore-scripts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.3.1",
    "html2canvas": "^1.4.1",
    "jose": "^6.2.2",
    "jspdf": "^4.2.1",
    "mqtt": "^5.15.1",
    "next": "16.2.1",
    "nodemailer": "^8.0.3",
    "promptpay-qr": "^0.5.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chokidar-cli": "^3.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "pm2": "^6.0.14",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
